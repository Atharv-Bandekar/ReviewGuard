import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Load the dataset
df = pd.read_csv('Final_enhanced_dataset.csv')

# 1. Basic Inspection
print("--- Dataset Info ---")
print(df.info())
print("\n--- Summary Statistics ---")
print(df.describe())

# 2. Label Distribution (Class Balance)
plt.figure(figsize=(6, 4))
sns.countplot(x='label', data=df, palette='viridis')
plt.title('Distribution of Labels (CG vs OR)')
plt.savefig('label_distribution.png')

# 3. Rating Distribution by Label
plt.figure(figsize=(10, 6))
sns.countplot(x='rating', hue='label', data=df, palette='magma')
plt.title('Rating Distribution by Label')
plt.savefig('rating_distribution.png')

# 4. Numeric Features Distribution comparison (CG vs OR)
features = ['vocab_richness', 'avg_word_len', 'sentence_count', 'text_length']
fig, axes = plt.subplots(2, 2, figsize=(14, 10))
axes = axes.flatten()

for i, col in enumerate(features):
    sns.kdeplot(data=df, x=col, hue='label', fill=True, common_norm=False, ax=axes[i])
    axes[i].set_title(f'Distribution of {col} by Label')

plt.tight_layout()
plt.savefig('numeric_distributions.png')

# 5. Correlation Heatmap
plt.figure(figsize=(10, 8))
corr = df.select_dtypes(include=['float64', 'int64']).corr()
sns.heatmap(corr, annot=True, cmap='coolwarm', fmt=".2f", linewidths=0.5)
plt.title('Correlation Heatmap of Numeric Features')
plt.savefig('correlation_heatmap.png')

# 6. Category Distribution
plt.figure(figsize=(12, 6))
sns.countplot(y='category', data=df, order=df['category'].value_counts().index, palette='Spectral')
plt.title('Distribution of Product Categories')
plt.tight_layout()
plt.savefig('category_distribution.png')