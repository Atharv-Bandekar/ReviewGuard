{
  "manifest_version": 3,
  "name": "ReviewGuard - E-Commerce Truth Detector",
  "version": "2.0",
  "description": "Detects fake, promotional, and AI-assisted product reviews on Amazon in real time.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:8000/*", 
    "https://www.amazon.com/*",
    "https://www.amazon.in/*",
    "https://www.amazon.co.uk/*",
    "https://www.amazon.ca/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*",
        "https://www.amazon.in/*",
        "https://www.amazon.co.uk/*",
        "https://www.amazon.ca/*"
      ],
      "js": ["content.js"]
    }
  ]
}